# .gitignore — Recomendado para mayor seguridad
# Revisa antes de ignorar archivos que quieras versionar (ej. lockfiles)

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env & secrets
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
envrc

# Credenciales y claves privadas
*.pem
*.key
*.p12
*.pfx
*.jks
*.crt
*.cert
*.asc
*.secret
*-key.json
service-account*.json
google-credentials.json
.aws/
.aws/credentials
.aws/config
.azure/
.gcloud/
.ssh/

# IDEs y editores
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Logs y reportes
*.log
logs/
npm-debug.log*
yarn-debug.log*

# Build / Output
/dist
/build
/out
/.next
/.cache
/coverage
/.nyc_output

# Sistema
.DS_Store
Thumbs.db

# Temporal / cachés
/tmp
/temp
*.tmp
.cache/

# Archivos de pruebas y resultados locales
/test-output

# Otros
*.env.*.local

# /docker-compose.override.yml

# Archivos temporales, de pruebas (scratch) y subidas de usuarios
/scratch/
test_*.js
test_*.cjs
test-*.js
test-*.cjs
/uploads/
*.sqlite
*.db

# Archivos de contexto y pruebas (No necesarios para el commit)
/*.txt
/*.pdf
/Ficha.md
/scripts/
/database/
/stress_test.js
.vercel
.env*
/base_de_datos/
